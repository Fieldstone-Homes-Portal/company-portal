generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(EMPLOYEE)
  department    String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model PortalApp {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  url         String
  minRole     Role     @default(EMPLOYEE)
  category    String   @default("general")
  // Which area of the portal this app shows up in.
  //   "tool"      → Toolbox page (apps grid at /dashboard) — DEFAULT
  //   "dashboard" → Dashboards page (/dashboards)
  // Stored as a free-form string so adding new sections later (e.g. "report")
  // doesn't require a migration.
  section     String   @default("tool")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  openIn      String   @default("iframe")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PortalFile {
  id          String   @id @default(cuid())
  name        String
  description String?
  path        String
  mimeType    String?
  size        Int?
  minRole     Role     @default(EMPLOYEE)
  category    String   @default("general")
  uploadedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
