generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(EMPLOYEE)
  // Legacy single-department field — kept for backward compat during the
  // transition. New code reads `departments` (many-to-many) instead.
  department    String?
  accounts      Account[]
  sessions      Session[]
  // Many-to-many: a user can belong to multiple departments.
  // Used by access-gating: EMPLOYEEs need to be in at least one of an
  // app's restricted departments to access it. MANAGERs and ADMINs bypass.
  departments   Department[] @relation("UserDepartments")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model PortalApp {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  url         String
  minRole     Role     @default(EMPLOYEE)
  category    String   @default("general")
  // Which area of the portal this app shows up in.
  //   "tool"      → Toolbox page (apps grid at /dashboard) — DEFAULT
  //   "dashboard" → Dashboards page (/dashboards)
  // Stored as a free-form string so adding new sections later (e.g. "report")
  // doesn't require a migration.
  section     String   @default("tool")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  openIn      String   @default("iframe")
  // Many-to-many: an app can be restricted to specific departments.
  //   Empty list  → no department restriction (anyone with the right role)
  //   Non-empty   → EMPLOYEEs need to be in at least one of these depts
  //                 (MANAGERs and ADMINs bypass — see lib/roles.ts)
  departments Department[] @relation("AppDepartments")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Department: a unit of the company (Construction, Sales, Land, etc.).
// Managed in the UI under /admin/departments. Used to restrict app access
// for employees — managers and admins ignore department gates.
model Department {
  id          String      @id @default(cuid())
  name        String      @unique
  description String?
  users       User[]      @relation("UserDepartments")
  apps        PortalApp[] @relation("AppDepartments")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model PortalFile {
  id          String   @id @default(cuid())
  name        String
  description String?
  path        String
  mimeType    String?
  size        Int?
  minRole     Role     @default(EMPLOYEE)
  category    String   @default("general")
  uploadedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
