generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

// Lifecycle stage of a portal app — a pipeline from first commit to fully
// released. Purely informational: it changes what badge users see on the
// app's tile, never who can access it (that's allStaff/departments/grants).
//   IN_DEV     → actively being built; expect changes and rough edges
//   VALIDATION → feature-complete, being tested/validated with a pilot group
//   MVP        → early access; core features work, more coming
//   DEPLOYED   → fully released and supported (default; no badge shown)
enum AppStage {
  IN_DEV
  VALIDATION
  MVP
  DEPLOYED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(EMPLOYEE)
  // Legacy single-department field — kept for backward compat during the
  // transition. New code reads `departments` (many-to-many) instead.
  department    String?
  accounts      Account[]
  sessions      Session[]
  // Many-to-many: a user can belong to multiple departments.
  // Used by access-gating: department grants on an app admit all of that
  // department's members. Only ADMINs bypass gating entirely.
  departments   Department[] @relation("UserDepartments")
  // Individual app grants (see AppGrant) — per-person access exceptions
  // managed by drag-and-drop in Access Studio.
  appGrants     AppGrant[]
  // Per-user "recently opened" history powering the Home page.
  recentOpens   RecentOpen[]
  // Append-only analytics events + usage sessions (see AppOpenEvent /
  // AppUsageSession below). Powers /admin/analytics.
  openEvents    AppOpenEvent[]
  usageSessions AppUsageSession[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model PortalApp {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  url         String
  category    String   @default("general")
  // Which area of the portal this app shows up in.
  //   "tool"      → Toolbox page (apps grid at /dashboard) — DEFAULT
  //   "dashboard" → Dashboards page (/dashboards)
  // Stored as a free-form string so adding new sections later (e.g. "report")
  // doesn't require a migration.
  section     String   @default("tool")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  openIn      String   @default("iframe")
  // Lifecycle stage (see the AppStage enum above). Informational only —
  // surfaced as a badge on tiles; existing apps default to DEPLOYED.
  stage       AppStage @default(DEPLOYED)
  // Access policy (union semantics — any one of these admits a user; only
  // ADMINs bypass gating entirely. See canAccessApp in lib/roles.ts):
  //   allStaff    → open to everyone. Overlays (doesn't clear) the grants
  //                 below, so removing the All-staff chip in Access Studio
  //                 reveals whatever policy was underneath.
  //   departments → members of any granted department (new members inherit)
  //   grants      → individual per-person exceptions
  allStaff    Boolean  @default(false)
  departments Department[] @relation("AppDepartments")
  grants      AppGrant[]
  // "What's New" entries about this app (see ReleaseNote below).
  releaseNotes ReleaseNote[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ReleaseNote: a "What's New" entry shown on the Home page and /whats-new.
// Created automatically when a manager registers a new app in Manage Apps
// (kind = "new-app"), or written by hand in /admin/releases (kind = "update").
//
//   appId    → optional link to a PortalApp. When set, the user-facing card
//              shows an "Open app →" link — but ONLY if the viewer passes
//              canAccessApp for that app (see lib/releaseNotes.ts). Deleting
//              the app keeps the note (appId nulls out) so history survives.
//   body     → plain text, rendered with line breaks preserved.
//   publishedAt → what the feed sorts by; notes dated in the future stay
//              hidden from users until that time passes.
//   createdBy → email of the manager/admin who created the note.
model ReleaseNote {
  id          String     @id @default(cuid())
  appId       String?
  app         PortalApp? @relation(fields: [appId], references: [id], onDelete: SetNull)
  title       String
  body        String?
  // "new-app" → auto-seeded when the app was registered; "update" → manual.
  // Free-form string so new kinds later don't need a migration.
  kind        String     @default("update")
  publishedAt DateTime   @default(now())
  createdBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([publishedAt])
}

// AppGrant: an individual person's access to an app — the per-user leg of
// the access policy, managed by drag-and-drop in Access Studio. Department
// membership and allStaff cover the broad strokes; this is for exceptions
// ("also let Jordan in"). One row per (app, user); granting twice is a no-op.
model AppGrant {
  id        String    @id @default(cuid())
  appId     String
  app       PortalApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Email of the admin who granted it (audit breadcrumb; null for rows
  // converted from the legacy minRole model).
  grantedBy String?
  createdAt DateTime  @default(now())

  @@unique([appId, userId])
  @@index([userId])
}

// Department: a unit of the company (Construction, Sales, Land, etc.).
// Managed in the UI under /admin/departments. Used to restrict app access
// for employees — managers and admins ignore department gates.
model Department {
  id          String      @id @default(cuid())
  name        String      @unique
  description String?
  users       User[]      @relation("UserDepartments")
  apps        PortalApp[] @relation("AppDepartments")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model PortalFile {
  id          String   @id @default(cuid())
  name        String
  description String?
  path        String
  mimeType    String?
  size        Int?
  minRole     Role     @default(EMPLOYEE)
  category    String   @default("general")
  uploadedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// RecentOpen: per-user "recently opened" history that powers the Home page's
// "Jump back in" row. One row per (user, kind, target) — re-opening an item
// just bumps `openedAt` (see the upsert in /api/track-open), so a user only
// ever has one row per distinct thing they've opened.
//
//   kind = "app"   → targetId is a PortalApp.id; the Home tile links to /apps/{targetId}
//   kind = "link"  → targetId is the external URL (also stored in `url`); the
//                    tile opens it in a new tab. `label`/`icon` are denormalized
//                    so the Home page can render without re-joining.
model RecentOpen {
  id       String   @id @default(cuid())
  userId   String
  kind     String
  targetId String
  label    String
  icon     String?
  url      String?
  openedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, targetId])
  @@index([userId, openedAt])
}

// AppOpenEvent: append-only log of every open, powering /admin/analytics.
// Unlike RecentOpen (which upserts — one row per user+target, so history is
// lost), every open inserts a new row here. Written by the same
// /api/track-open request that bumps RecentOpen.
//
// Privacy: app-level only. We record WHO opened WHICH app/link and WHEN —
// never URLs inside an app, page views within it, or anything the user did
// there.
//
//   kind = "app"  → targetId = PortalApp.id
//   kind = "link" → targetId = the company link's URL
// `label` is denormalized (name at open time) so analytics can still show
// something meaningful for apps that are later deleted.
model AppOpenEvent {
  id       String   @id @default(cuid())
  userId   String
  kind     String
  targetId String
  label    String
  openedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([openedAt])
  @@index([kind, targetId, openedAt])
}

// AppUsageSession: lightweight time-on-app tracking for embedded apps.
// AppEmbed generates a random sessionKey on mount and sends a heartbeat to
// /api/track-usage every 60s while the tab is visible (plus a final beacon on
// hide/close). Each heartbeat adds the elapsed time since the previous one to
// `activeSeconds`, capped server-side so hidden/suspended gaps never count.
// One row per embed session; analytics sums activeSeconds per app.
//
// Only iframe-embedded apps are timed — external links open in a new tab we
// can't (and shouldn't) observe. Same privacy stance as AppOpenEvent:
// app-level only, no in-app activity of any kind.
model AppUsageSession {
  id            String   @id @default(cuid())
  // Client-generated random key identifying one continuous embed session.
  // Unique so heartbeats can upsert; always validated against userId.
  sessionKey    String   @unique
  userId        String
  kind          String
  targetId      String
  startedAt     DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  // Accumulated visible time in seconds (sum of capped heartbeat deltas).
  activeSeconds Int      @default(0)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([startedAt])
  @@index([kind, targetId, startedAt])
}
